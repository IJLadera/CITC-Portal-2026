{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "paths" : {
      "@" : ["./src/"],
      "@/*" : ["./src/*"],
      "@application/*" : ["./src/pages/Application/*"],
      "@lms/*" : ["./src/pages/Application/pages/lms/*"],
      "@class/*" : ["./src/pages/Application/pages/lms/pages/class/*"],
      "@lesson/*" : ["./src/pages/Application/pages/lms/pages/lesson/*"],
      "@http" : ["./src/http"],
      "@store" : ["./src/store"],
      "@hooks" : ["./src/hooks"],
    },
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules", "src/**/*.spec.ts"]
}
